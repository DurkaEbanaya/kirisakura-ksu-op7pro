+	/* tetherctrl_FORWARD chain head */
+	chain_off = bytes;
+	{
+		struct ip6t_error *ch = (struct ip6t_error *)(data + bytes);
+		*ch = (struct ip6t_error)IP6T_ERROR_INIT;
+		strncpy(ch->target.errorname, "tetherctrl_FORWARD",
+			sizeof(ch->target.errorname));
+		bytes += err_sz;
+	}
+
+	/* tetherctrl_FORWARD return */
+	{
+		struct ip6t_standard *r = (struct ip6t_standard *)(data + bytes);
+		*r = (struct ip6t_standard)IP6T_STANDARD_INIT(NF_ACCEPT);
+		bytes += std_sz;
+	}
+
+	/* tetherctrl_counters chain head */
+	{
+		struct ip6t_error *ch = (struct ip6t_error *)(data + bytes);
+		*ch = (struct ip6t_error)IP6T_ERROR_INIT;
+		strncpy(ch->target.errorname, "tetherctrl_counters",
