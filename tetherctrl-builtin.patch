+	 *   [6] tetherctrl_counters chain head (error target)
+	 *   [7] tetherctrl_counters return -> ACCEPT
+	 *   [8] ERROR
+	 */
+	std_sz = sizeof(struct ip6t_standard);
+	err_sz = sizeof(struct ip6t_error);
+	hook_mask = packet_filter.valid_hooks;
+	nhooks = hweight32(hook_mask);
