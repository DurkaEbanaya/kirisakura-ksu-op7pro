+		*r = (struct ip6t_standard)IP6T_STANDARD_INIT(NF_ACCEPT);
+		bytes += std_sz;
+	}
+
+	/* ERROR entry */
+	{
+		struct ip6t_error *t = (struct ip6t_error *)(data + bytes);
+		*t = (struct ip6t_error)IP6T_ERROR_INIT;
+	}
+
+	/* Set FORWARD hook jump to tetherctrl_FORWARD */
+	{
+		struct ip6t_standard *fwd = (struct ip6t_standard *)
+			(data + forward_hook_off);
+		fwd->target.verdict = chain_off;
+	}
 
 	err = ip6t_register_table(net, &packet_filter, repl, filter_ops,
 				  &net->ipv6.ip6table_filter);
-	kfree(repl);
+	kfree(buf);
 	return err;
 }
 
