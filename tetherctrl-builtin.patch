 		return -ENOMEM;
-	/* Entry 1 is the FORWARD hook */
-	((struct ip6t_standard *)repl->entries)[1].target.verdict =
-		forward ? -NF_ACCEPT - 1 : -NF_DROP - 1;
+
+	repl = buf;
+	data = buf + sizeof(*repl);
+
+	strncpy(repl->name, packet_filter.name, sizeof(repl->name));
+	repl->valid_hooks = hook_mask;
+	repl->num_entries = nhooks + 6;
+	repl->size = total_sz;
+
+	hooknum = 0;
+	bytes = 0;
+	for (; hook_mask != 0; hook_mask >>= 1, ++hooknum) {
+		struct ip6t_standard *e;
+		if (!(hook_mask & 1))
+			continue;
+
+		if (hooknum == NF_INET_FORWARD) {
+			repl->hook_entry[hooknum] = bytes;
+			forward_hook_off = bytes;
+			e = (struct ip6t_standard *)(data + bytes);
+			*e = (struct ip6t_standard)IP6T_STANDARD_INIT(NF_ACCEPT);
+			bytes += std_sz;
+
+			repl->underflow[hooknum] = bytes;
+			e = (struct ip6t_standard *)(data + bytes);
+			*e = (struct ip6t_standard)IP6T_STANDARD_INIT(NF_ACCEPT);
+			bytes += std_sz;
+		} else {
+			repl->hook_entry[hooknum] = bytes;
+			repl->underflow[hooknum] = bytes;
+			e = (struct ip6t_standard *)(data + bytes);
+			*e = (struct ip6t_standard)IP6T_STANDARD_INIT(NF_ACCEPT);
+			bytes += std_sz;
