-/* Default to forward because I got too much mail already. */
 static bool forward = true;
 module_param(forward, bool, 0000);
 
 static int __net_init ip6table_filter_table_init(struct net *net)
 {
-	struct ip6t_replace *repl;
 	int err;
+	void *buf;
