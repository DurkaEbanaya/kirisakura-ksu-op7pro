diff --git a/net/ipv4/netfilter/iptable_filter.c b/net/ipv4/netfilter/iptable_filter.c
index 7667f223d..3189fa303 100644
--- a/net/ipv4/netfilter/iptable_filter.c
+++ b/net/ipv4/netfilter/iptable_filter.c
@@ -55,22 +55,99 @@ module_param(forward, bool, 0000);
 
 static int __net_init iptable_filter_table_init(struct net *net)
 {
-	struct ipt_replace *repl;
 	int err;
+	void *buf;
+	struct ipt_replace *repl;
+	char *data;
+	unsigned int hook_mask, nhooks, hooknum;
+	unsigned int bytes;
+	size_t std_sz, err_sz, total_sz;
 
 	if (net->ipv4.iptable_filter)
 		return 0;
 
-	repl = ipt_alloc_initial_table(&packet_filter);
-	if (repl == NULL)
+	/*
+	 * Build initial table with tetherctrl_counters chain pre-created.
+	 *
+	 * On Android 11, netd's TetherController::setupChains() fails to
+	 * create the tetherctrl_counters chain in the IPv4 filter table.
+	 * This causes setForwardRules() to fail with "goto 'tetherctrl_counters'
+	 * is not a chain", preventing hotspot/tethering from working.
+	 *
+	 * Pre-creating the chain in the kernel's initial table structure
+	 * ensures it exists from boot. netd's ":tetherctrl_counters -"
+	 * becomes a no-op (with --noflush) and setForwardRules() succeeds.
+	 *
+	 * Layout (6 entries):
+	 *   [0] INPUT    -> ACCEPT (hook+underflow)
+	 *   [1] FORWARD  -> ACCEPT/DROP (hook+underflow, based on forward param)
+	 *   [2] OUTPUT   -> ACCEPT (hook+underflow)
+	 *   [3] tetherctrl_counters chain head (error target)
+	 *   [4] tetherctrl_counters return -> ACCEPT
+	 *   [5] ERROR
+	 */
+	std_sz = sizeof(struct ipt_standard);
+	err_sz = sizeof(struct ipt_error);
+	hook_mask = packet_filter.valid_hooks;
+	nhooks = hweight32(hook_mask);
+	/* 3 hook entries + 1 return = (nhooks+1) standard; 2 error (chain head + ERROR) */
+	total_sz = (nhooks + 1) * std_sz + 2 * err_sz;
+
+	buf = kzalloc(sizeof(*repl) + total_sz, GFP_KERNEL);
+	if (!buf)
 		return -ENOMEM;
-	/* Entry 1 is the FORWARD hook */
-	((struct ipt_standard *)repl->entries)[1].target.verdict =
-		forward ? -NF_ACCEPT - 1 : -NF_DROP - 1;
+
+	repl = buf;
+	data = buf + sizeof(*repl);
+
+	strncpy(repl->name, packet_filter.name, sizeof(repl->name));
+	repl->valid_hooks = hook_mask;
+	repl->num_entries = nhooks + 3; /* hooks + chain_head + return + ERROR */
+	repl->size = total_sz;
+
+	hooknum = 0;
+	bytes = 0;
+	for (; hook_mask != 0; hook_mask >>= 1, ++hooknum) {
+		struct ipt_standard *e;
+		if (!(hook_mask & 1))
+			continue;
+
+		repl->hook_entry[hooknum] = bytes;
+		repl->underflow[hooknum] = bytes;
+		e = (struct ipt_standard *)(data + bytes);
+		if (hooknum == NF_INET_FORWARD)
+			*e = (struct ipt_standard)IPT_STANDARD_INIT(
+				forward ? NF_ACCEPT : NF_DROP);
+		else
+			*e = (struct ipt_standard)IPT_STANDARD_INIT(NF_ACCEPT);
+		bytes += std_sz;
+	}
+
+	/* tetherctrl_counters chain head */
+	{
+		struct ipt_error *ch = (struct ipt_error *)(data + bytes);
+		*ch = (struct ipt_error)IPT_ERROR_INIT;
+		strncpy(ch->target.errorname, "tetherctrl_counters",
+			sizeof(ch->target.errorname));
+		bytes += err_sz;
+	}
+
+	/* tetherctrl_counters return */
+	{
+		struct ipt_standard *r = (struct ipt_standard *)(data + bytes);
+		*r = (struct ipt_standard)IPT_STANDARD_INIT(NF_ACCEPT);
+		bytes += std_sz;
+	}
+
+	/* ERROR entry */
+	{
+		struct ipt_error *t = (struct ipt_error *)(data + bytes);
+		*t = (struct ipt_error)IPT_ERROR_INIT;
+	}
 
 	err = ipt_register_table(net, &packet_filter, repl, filter_ops,
 				 &net->ipv4.iptable_filter);
-	kfree(repl);
+	kfree(buf);
 	return err;
 }
 
diff --git a/net/ipv6/netfilter/Makefile b/net/ipv6/netfilter/Makefile
index c6ee0cdd0..9e55eb065 100644
--- a/net/ipv6/netfilter/Makefile
+++ b/net/ipv6/netfilter/Makefile
@@ -4,23 +4,27 @@
 #
 
 # Link order matters here.
+# IPv6 conntrack must init BEFORE NAT table/hooks (matches IPv4 order)
 obj-$(CONFIG_IP6_NF_IPTABLES) += ip6_tables.o
 obj-$(CONFIG_IP6_NF_FILTER) += ip6table_filter.o
 obj-$(CONFIG_IP6_NF_MANGLE) += ip6table_mangle.o
 obj-$(CONFIG_IP6_NF_RAW) += ip6table_raw.o
 obj-$(CONFIG_IP6_NF_SECURITY) += ip6table_security.o
-obj-$(CONFIG_IP6_NF_NAT) += ip6table_nat.o
 
 # objects for l3 independent conntrack
 nf_conntrack_ipv6-y  :=  nf_conntrack_l3proto_ipv6.o nf_conntrack_proto_icmpv6.o
 
-# l3 independent conntrack
+# l3 independent conntrack (must init before NAT l3proto and table)
 obj-$(CONFIG_NF_CONNTRACK_IPV6) += nf_conntrack_ipv6.o
 
+# NAT l3proto (must init before NAT table/hooks)
 nf_nat_ipv6-y		:= nf_nat_l3proto_ipv6.o nf_nat_proto_icmpv6.o
 obj-$(CONFIG_NF_NAT_IPV6) += nf_nat_ipv6.o
 obj-$(CONFIG_NF_NAT_MASQUERADE_IPV6) += nf_nat_masquerade_ipv6.o
 
+# NAT table + hooks (must init AFTER conntrack and NAT l3proto)
+obj-$(CONFIG_IP6_NF_NAT) += ip6table_nat.o
+
 # defrag
 nf_defrag_ipv6-y := nf_defrag_ipv6_hooks.o nf_conntrack_reasm.o
 obj-$(CONFIG_NF_DEFRAG_IPV6) += nf_defrag_ipv6.o
